// This is your Prisma schema file
// Learn more about it at: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUSINESS
  PLATFORM_ADMIN
  ADMIN
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  ICAL
  PMS
  NONE
}

model Client {
  id              String    @id @default(cuid())
  clerkUserId     String    @unique
  email           String    @unique
  role            UserRole  @default(BUSINESS)
  businessName    String?
  businessType    String?   // "peluqueria", "medico", "restaurante", etc.
  city            String?
  agentName       String?   @default("Asistente")
  agentTone       String?   @default("profesional") 
  agentVoice      String?   @default("male") // "male" | "female"
  phone           String?   
  transferPhone   String?   
  retellAgentId   String?   
  netelipNumberId String?   
  databaseUrl     String?   
  agentPrompt     String?   @db.Text
  onboardingStep  Int       @default(0)
  onboardingDone  Boolean   @default(false)
  isActive        Boolean   @default(true)

  // Stripe Subscription
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?   // ID del precio/plan en Stripe
  subscriptionPlan     String?   // "monthly", "biannual", "annual"
  subscriptionStatus   String?   @default("inactive") // "active", "past_due", "canceled", "inactive"
  subscriptionStart    DateTime?
  subscriptionEnd      DateTime?
  trialEnd             DateTime?
  lastPaymentAt        DateTime?
  renewalReminderSent  Boolean   @default(false)
  renewalReminderSentAt DateTime?

  // Calendar Configuration
  activeCalendarProvider CalendarProvider @default(GOOGLE)

  // Google Calendar OAuth
  googleAccessToken  String?  @db.Text
  googleRefreshToken String?  @db.Text
  googleTokenExpiry  DateTime?
  calendarId         String?  @default("primary")

  // Microsoft OAuth
  microsoftAccessToken  String?  @db.Text
  microsoftRefreshToken String?  @db.Text
  microsoftTokenExpiry  DateTime?
  microsoftCalendarId   String?

  // PMS Integration
  pmsProvider String? // "CLOUDBEDS", "MEWS", etc.
  pmsApiKey   String? @db.Text
  pmsUrl      String? @db.Text
  pmsActive   Boolean @default(false)
  icalUrl     String? @db.Text

  // CRM Integration
  crmProvider String? // "HUBSPOT", "PIPEDRIVE", "SALESFORCE", "ZOHO"
  crmApiKey   String? @db.Text
  crmUrl      String? @db.Text
  crmActive   Boolean @default(false)
  crmClientId     String? @db.Text
  crmClientSecret String? @db.Text
  crmRefreshToken String? @db.Text

  // Restaurant Integration
  restaurantProvider String? // "COVERMANAGER", "THEFORK", "OPENTABLE", "REVO"
  restaurantApiKey   String? @db.Text
  restaurantUrl      String? @db.Text
  restaurantActive   Boolean @default(false)

  // Integration Intent (Onboarding)
  wantsGoogleCalendar   Boolean @default(false)
  wantsMicrosoftOutlook Boolean @default(false)
  wantsCRM              Boolean @default(false)
  wantsPMS              Boolean @default(false)
  wantsRestaurant       Boolean @default(false)

  // Relaciones
  staff     Staff[]
  services  Service[]
  schedules Schedule[]
  callLogs  CallLog[]
  appointments Appointment[]
  botLogs      BotLog[]
  tickets      Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Staff {
  id               String  @id @default(cuid())
  clientId         String
  name             String
  email            String?
  googleCalendarId String? @default("primary")
  isActive         Boolean @default(true)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Relaciones específicas de staff
  services  Service[]
  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("staff")
}

model Service {
  id          String  @id @default(cuid())
  clientId    String
  staffId     String? // Opcional: si el servicio es de todo el negocio o de alguien concreto
  name        String
  description String?
  durationMin Int     @default(30)
  price       Float?
  isActive    Boolean @default(true)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff  Staff? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@map("services")
}

model Schedule {
  id        String  @id @default(cuid())
  clientId  String
  staffId   String? // Opcional: horario general o del profesional
  dayOfWeek Int     // 0=Lunes, 1=Martes ... 6=Domingo
  openTime  String  // "09:00"
  closeTime String  // "20:00"
  isOpen    Boolean @default(true)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff  Staff? @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([clientId, staffId, dayOfWeek])
  @@map("schedules")
}

model CallLog {
  id            String   @id @default(cuid())
  clientId      String
  retellCallId  String?  @unique
  callerNumber  String?
  durationSec   Int?
  summary       String?  @db.Text
  transcript    String?  @db.Text
  actionTaken   String?  // "booked", "modified", "cancelled", "transferred", "info"
  appointmentId String?  // ID del evento en Google Calendar

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("call_logs")
}

model Appointment {
  id            String   @id @default(cuid())
  clientId      String
  callerName    String
  callerPhone   String?
  serviceName   String
  staffName     String?
  date          String   // YYYY-MM-DD
  time          String   // HH:MM
  status        String   @default("CONFIRMED") // "CONFIRMED", "CANCELLED"
  notes         String?
  numGuests     Int?     // Para restaurantes
  externalId    String?  // ID en Google Calendar o similar

  // SMS Reminders
  smsConfirmationSent   Boolean   @default(false)
  smsConfirmationSentAt DateTime?
  smsReminderSent       Boolean   @default(false)
  smsReminderSentAt     DateTime?
  smsCancellationSent   Boolean   @default(false)
  smsCancellationSentAt DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model BotLog {
  id           String   @id @default(cuid())
  clientId     String
  functionName String
  inputArgs    String   @db.Text
  resultJson   String?  @db.Text
  slotsFound   Int?
  scheduleUsed String?  @db.Text
  errorMsg     String?  @db.Text
  durationMs   Int?
  webhookUrl   String?  @db.Text
  confirmed    Boolean?
  createdAt    DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("bot_logs")
}

model Prospect {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  plan                String    @default("biannual") // "monthly", "biannual", "annual"
  notes               String?   @db.Text
  status              String    @default("pending") // "pending", "paid", "onboarded", "expired"
  paymentUrl          String?   @db.Text
  paymentLinkSentAt   DateTime?
  paymentLinkSentBy   String?   // admin user id
  paidAt              DateTime?
  stripeSessionId     String?   @unique
  onboardingLinkSentAt DateTime?
  
  // Follow-up tracking
  reminder24hSentAt   DateTime?
  reminder3dSentAt   DateTime?
  reminder7dSentAt   DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("prospects")
}

model Invitation {
  id           String   @id @default(cuid())
  email        String
  businessName String?
  token        String   @unique
  status       String   @default("PENDING") // "PENDING", "ACCEPTED", "EXPIRED"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("invitations")
}

model Ticket {
  id          String   @id @default(cuid())
  clientId    String
  subject     String
  description String   @db.Text
  category    String   // "tecnico" | "integracion" | "consulta"
  status      String   @default("open") // "open" | "in_progress" | "resolved" | "closed"
  priority    String   @default("normal") // "low" | "normal" | "high"
  adminNotes  String?  @db.Text
  resolvedAt  DateTime?
  
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("tickets")
}
