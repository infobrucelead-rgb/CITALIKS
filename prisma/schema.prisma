generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                     String           @id @default(cuid())
  clerkUserId            String           @unique
  email                  String           @unique
  role                   UserRole         @default(BUSINESS)
  businessName           String?
  businessType           String?
  city                   String?
  agentName              String?          @default("Asistente")
  agentTone              String?          @default("profesional")
  phone                  String?
  transferPhone          String?
  retellAgentId          String?
  netelipNumberId        String?
  databaseUrl            String?
  agentPrompt            String?
  onboardingStep         Int              @default(0)
  onboardingDone         Boolean          @default(false)
  isActive               Boolean          @default(true)
  stripeCustomerId       String?          @unique
  stripeSubscriptionId   String?          @unique
  stripePriceId          String?
  subscriptionPlan       String?
  subscriptionStatus     String?          @default("inactive")
  subscriptionStart      DateTime?
  subscriptionEnd        DateTime?
  trialEnd               DateTime?
  lastPaymentAt          DateTime?
  renewalReminderSent    Boolean          @default(false)
  renewalReminderSentAt  DateTime?
  googleAccessToken      String?
  googleRefreshToken     String?
  googleTokenExpiry      DateTime?
  calendarId             String?          @default("primary")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  agentVoice             String?          @default("male")
  activeCalendarProvider CalendarProvider @default(GOOGLE)
  microsoftAccessToken   String?
  microsoftCalendarId    String?
  microsoftRefreshToken  String?
  microsoftTokenExpiry   DateTime?
  pmsActive              Boolean          @default(false)
  pmsApiKey              String?
  pmsProvider            String?
  pmsUrl                 String?
  icalUrl                String?
  crmActive              Boolean          @default(false)
  crmApiKey              String?
  crmProvider            String?
  crmUrl                 String?
  wantsCRM               Boolean          @default(false)
  wantsGoogleCalendar    Boolean          @default(false)
  wantsMicrosoftOutlook  Boolean          @default(false)
  wantsPMS               Boolean          @default(false)
  restaurantActive       Boolean          @default(false)
  restaurantApiKey       String?
  restaurantProvider     String?
  restaurantUrl          String?
  wantsRestaurant        Boolean          @default(false)
  crmClientId            String?
  crmClientSecret        String?
  crmRefreshToken        String?
  icalToken              String?          @unique
  appointments           Appointment[]
  botLogs                BotLog[]
  callLogs               CallLog[]
  schedules              Schedule[]
  services               Service[]
  staff                  Staff[]
  tickets                Ticket[]

  @@map("clients")
}

model Staff {
  id               String     @id @default(cuid())
  clientId         String
  name             String
  email            String?
  googleCalendarId String?    @default("primary")
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  schedules        Schedule[]
  services         Service[]
  client           Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("staff")
}

model Service {
  id          String  @id @default(cuid())
  clientId    String
  staffId     String?
  name        String
  description String?
  durationMin Int     @default(30)
  price       Float?
  isActive    Boolean @default(true)
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff       Staff?  @relation(fields: [staffId], references: [id])

  @@map("services")
}

model Schedule {
  id        String  @id @default(cuid())
  clientId  String
  staffId   String?
  dayOfWeek Int
  openTime  String
  closeTime String
  isOpen    Boolean @default(true)
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff     Staff?  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([clientId, staffId, dayOfWeek])
  @@map("schedules")
}

model CallLog {
  id            String   @id @default(cuid())
  clientId      String
  retellCallId  String?  @unique
  callerNumber  String?
  durationSec   Int?
  summary       String?
  transcript    String?
  actionTaken   String?
  appointmentId String?
  createdAt     DateTime @default(now())
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("call_logs")
}

model Appointment {
  id                    String    @id @default(cuid())
  clientId              String
  callerName            String
  callerPhone           String?
  serviceName           String
  staffName             String?
  date                  String
  time                  String
  status                String    @default("CONFIRMED")
  notes                 String?
  externalId            String?
  smsConfirmationSent   Boolean   @default(false)
  smsConfirmationSentAt DateTime?
  smsReminderSent       Boolean   @default(false)
  smsReminderSentAt     DateTime?
  smsCancellationSent   Boolean   @default(false)
  smsCancellationSentAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  numGuests             Int?
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model BotLog {
  id           String   @id @default(cuid())
  clientId     String
  functionName String
  inputArgs    String
  resultJson   String?
  slotsFound   Int?
  scheduleUsed String?
  errorMsg     String?
  durationMs   Int?
  webhookUrl   String?
  confirmed    Boolean?
  createdAt    DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("bot_logs")
}

model Prospect {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  plan                 String    @default("biannual")
  notes                String?
  status               String    @default("pending")
  paymentLinkSentAt    DateTime?
  paymentLinkSentBy    String?
  paidAt               DateTime?
  stripeSessionId      String?   @unique
  onboardingLinkSentAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  paymentUrl           String?
  reminder24hSentAt    DateTime?
  reminder3dSentAt     DateTime?
  reminder7dSentAt     DateTime?

  @@map("prospects")
}

model Invitation {
  id           String   @id @default(cuid())
  email        String
  businessName String?
  token        String   @unique
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("invitations")
}

model Ticket {
  id          String    @id @default(cuid())
  clientId    String
  subject     String
  description String
  category    String
  status      String    @default("open")
  priority    String    @default("normal")
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@map("tickets")
}

enum UserRole {
  BUSINESS
  PLATFORM_ADMIN
  ADMIN
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  ICAL
  PMS
  NONE
}
