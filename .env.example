# Cita Liks — Variables de Entorno
# Copia este archivo como .env.local y rellena los valores

# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cita_liks"

# ─── Clerk (Auth) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Retell AI ───────────────────────────────────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxx

# ─── Google OAuth2 ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
# URL que Google redirige tras el login OAuth del cliente
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ─── Netelip (Telefonía +34) ─────────────────────────────────────────────────
NETELIP_API_TOKEN=6687cdc4b1f996d3577706cf0231bab2eaee2d1cf5ccea35c1b6ecdb3fab6e16

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=genera_un_secret_largo_aleatorio_aqui

# ─── Cron Secret ─────────────────────────────────────────────────────────────
# Protege los endpoints /api/sms/reminders y /api/stripe/subscription-cron
# Genera con: openssl rand -hex 32
CRON_SECRET=genera_un_secret_largo_aqui

# ─── Stripe (Suscripciones y Facturación) ────────────────────────────────────
# Obtén las claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Obtén el webhook secret en: https://dashboard.stripe.com/webhooks
# Endpoint a registrar: https://tudominio.com/api/stripe/webhook
# Eventos a escuchar: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs de precio de los planes (créalos en Stripe Dashboard > Products)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_BIANNUAL=price_...
STRIPE_PRICE_ANNUAL=price_...

# ─── SMTP (Gmail / Google Workspace) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
SMTP_FROM="CitaLiks" <tu-email@gmail.com>
